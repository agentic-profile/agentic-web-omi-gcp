rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Accounts: Only the owner can read or write their own account document
    match /accounts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Memories: Only the owner can read or delete their memories.
    // Creation is usually handled by the server Admin SDK (bypass rules), 
    // but we allow client-side creation if the userId matches.
    match /memories/{memoryId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if false; // Memories are immutable
    }

    // API Keys: Only the owner can manage their API keys
    match /apiKeys/{keyId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // OTPs: Used for the publishing flow
    match /otps/{otpId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // Default deny: Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
    
    // NOTE: All server-side access (Admin SDK) bypasses these rules.
    // This allows webhooks and server endpoints to function while keeping
    // the client-side access strictly secured.
  }
}
